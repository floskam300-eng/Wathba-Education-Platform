# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Wathba Live Service — Environment Variables
# انسخ الملف ده لـ .env وعبّي القيم
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# LiveKit API credentials (نفس القيم في Replit Secrets)
LIVEKIT_API_KEY=wathba-key
LIVEKIT_API_SECRET=REPLACE_WITH_YOUR_GENERATED_SECRET

# الـ Domain بتاع الـ VPS
LIVEKIT_DOMAIN=live.wathba.site
