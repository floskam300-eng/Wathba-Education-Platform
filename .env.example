# ─────────────────────────────────────────────
#  WATHBA — Environment Variables
#  انسخ الملف ده لـ .env وعبي القيم
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ──────────────────────────────────
# مثال: postgresql://postgres:password@localhost:5432/wathba
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/wathba

# ── Auth ──────────────────────────────────────
# غير القيمة دي لأي string طويل عشوائي
JWT_SECRET=change-this-to-a-long-random-secret

# ── CORS / Domain ─────────────────────────────
# الـ domain الأساسي بتاعك (بدون https://)
WILDCARD_DOMAIN=wathba.site
# قائمة origins مسموح بيها (اختياري لو حطيت WILDCARD_DOMAIN)
ALLOWED_ORIGINS=https://wathba.site,https://api.wathba.site

# ── Firebase (اختياري — للـ push notifications) ──
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── LiveKit (اختياري — للـ livestreaming، هنأجله) ──
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://live.wathba.site
